<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep"
    android:gravity="center"
    android:padding="32dp">

    <!-- Logo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AntiGravity X"
        android:textColor="@color/accent"
        android:textSize="28sp"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overlay Menu — v1.0"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="40dp"/>

    <!-- Permission Status -->
    <TextView
        android:id="@+id/tv_permission_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking permission..."
        android:textSize="13sp"
        android:layout_marginBottom="32dp"/>

    <!-- Launch Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_launch_overlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_launch"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        app:backgroundTint="@color/accent"
        app:cornerRadius="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- Stop Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_stop_overlay"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/btn_stop"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        app:backgroundTint="@color/surface"
        app:strokeColor="@color/accent"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"/>

    <!-- Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/perm_desc"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textAlignment="center"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginTop="28dp"/>

</LinearLayout>
